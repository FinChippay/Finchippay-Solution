# frontend/.env.example
# Copy this file to frontend/.env.local and fill in your values.
#
# Required variables are marked with [REQUIRED].
# All others have sensible defaults or are optional.

# ─── Stellar Network [REQUIRED] ────────────────────────────────────────────────
# Must be "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Stellar Horizon API base URL [REQUIRED]
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Backend API base URL [REQUIRED]
# Host root only — client code calls /api/v1/* paths (#83).
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Soroban Smart Contract (optional) ────────────────────────────────────────
# Deployed FinchippayContract contract ID (v2 with pause/upgrade/bounds)
# Run: bash scripts/deploy-contract.sh testnet <identity>
# NEXT_PUBLIC_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Soroban RPC endpoint (optional)
# NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Soroban network passphrase (auto-set from STELLAR_NETWORK if unset)
# NEXT_PUBLIC_SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Error Tracking (optional) ────────────────────────────────────────────────
# Sentry DSN for client-side error monitoring. Disabled if unset.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/1234567

# ─── Feature Flags (client-side overrides) ───────────────────────────────────
# JSON object for local/development flag overrides. Only applies when the
# server endpoint /api/features is unreachable or returns no value for a flag.
# Example:
#   NEXT_PUBLIC_FEATURE_FLAGS={"trading_page":{"enabled":true}}
